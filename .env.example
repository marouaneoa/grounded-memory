
# =============================================================================
# gmem Runtime
# =============================================================================

# Adapter key
GM_ADAPTER=healthcare

# Storage mode: memory | hybrid | postgres | postgres_hybrid
GM_STORAGE_BACKEND=postgres_hybrid

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=35432
POSTGRES_DB=grounded_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# Neo4j
# =============================================================================
NEO4J_HOST=127.0.0.1
NEO4J_URI=bolt://127.0.0.1:37687
NEO4J_BOLT_PORT=37687
NEO4J_HTTP_PORT=37474
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# =============================================================================
# LLM Provider
# =============================================================================
LLM_PROVIDER=openrouter
LLM_MODEL=google/gemma-4-31b-it

# OpenRouter key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_SITE_NAME=gmem
OPENROUTER_SITE_URL=

# Generation
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
